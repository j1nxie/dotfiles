[
    {
        "context": "VimControl && !menu",
        "bindings": {
            "H": [
                "vim::StartOfLine",
                {
                    "display_lines": true
                }
            ],
            "L": [
                "vim::EndOfLine",
                {
                    "display_lines": true
                }
            ],
            "space c a": "editor::ToggleCodeActions",
            "left": "pane::ActivatePreviousItem",
            "right": "pane::ActivateNextItem",
            "up": null,
            "down": null,
            "space p p ": [
                "projects::OpenRecent",
                {
                    "create_new_window": false
                }
            ],
            "j": [
                "vim::Down",
                {
                    "display_lines": true
                }
            ],
            "k": [
                "vim::Up",
                {
                    "display_lines": true
                }
            ],
            "space space": "file_finder::Toggle"
        }
    },
    {
        "context": "Editor && showing_code_actions",
        "bindings": {
            "j": "editor::ContextMenuNext",
            "k": "editor::ContextMenuPrevious"
        }
    },
    {
        "context": "Editor && showing_completions",
        "bindings": {
            "tab": "editor::ContextMenuNext",
            "shift-tab": "editor::ContextMenuPrevious"
        }
    },
    {
        "context": "vim_mode == normal || Dock",
        "bindings": {
            "ctrl-h": "workspace::ActivatePaneLeft",
            "ctrl-l": "workspace::ActivatePaneRight",
            "ctrl-k": "workspace::ActivatePaneUp",
            "ctrl-j": "workspace::ActivatePaneDown"
        }
    },
    {
        "context": "vim_mode == normal && (Editor || Dock)",
        "bindings": {
            "f5": "project_panel::ToggleFocus",
            "space o t": "terminal_panel::ToggleFocus",
            "space o shift-t": "task::Spawn"
        }
    },
    {
        "context": "EmptyPane || SharedScreen",
        "bindings": {
            "space space": "file_finder::Toggle",
            "space f p": "projects::OpenRecent"
        }
    },
    {
        "context": "ProjectPanel && not_editing",
        "bindings": {
            "a": "project_panel::NewFile",
            "A": "project_panel::NewDirectory",
            "r": "project_panel::Rename",
            "d": "project_panel::Delete",
            "x": "project_panel::Cut",
            "c": "project_panel::Copy",
            "p": "project_panel::Paste",
            // Close project panel as project file panel on the right
            "q": "workspace::ToggleRightDock",
            "space e": "workspace::ToggleRightDock",
            // Navigate between panel
            "ctrl-h": "workspace::ActivatePaneLeft",
            "ctrl-l": "workspace::ActivatePaneRight",
            "ctrl-k": "workspace::ActivatePaneUp",
            "ctrl-j": "workspace::ActivatePaneDown"
        }
    },
]
